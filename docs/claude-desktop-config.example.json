{
  "mcpServers": {
    "powerbi-auth-by-account": {
      "command": "node",
      "args": ["/Users/<you>/powerBI-auth-by-account/dist/server.js"],
      "env": {
        "POWERBI_KNOWN_WORKSPACES": "test-mcp",
        "POWERBI_DEFAULT_WORKSPACE": "test-mcp",
        "POWERBI_MODELING_MCP_COMMAND": "/Users/<you>/powerBI-auth-by-account/node_modules/.bin/powerbi-modeling-mcp-darwin-arm64",
        "POWERBI_MODELING_MCP_ARGS": "--start --authmode=interactive"
      }
    }
  }
}
