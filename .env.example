# Optional direct delegated personal-account access token
# POWERBI_ACCESS_TOKEN=

# Personal account tenant. Use organizations, a tenant domain, or tenant ID.
POWERBI_TENANT=vnu.edu.vn

# Optional token cache for start_device_login / complete_device_login
# POWERBI_TOKEN_CACHE=/Users/ducna/.mcp-powerbi/token-cache.json

# Optional override for the Microsoft Power BI Modeling MCP bridge.
# Defaults to: npx -y @microsoft/powerbi-modeling-mcp@latest --start
# POWERBI_MODELING_MCP_COMMAND=npx
# POWERBI_MODELING_MCP_ARGS=-y @microsoft/powerbi-modeling-mcp@latest --start

# Claude/Desktop example after `npm install` in this repo:
# POWERBI_MODELING_MCP_COMMAND=/Users/ducna/powerBI-auth-by-account/node_modules/.bin/powerbi-modeling-mcp-darwin-arm64
# POWERBI_MODELING_MCP_ARGS=--start

# Optional CEO defaults. Known workspaces replace tenant-wide REST discovery
# when service-principal/REST auth is not configured.
# POWERBI_KNOWN_WORKSPACES=test-mcp,finance,hospital
# POWERBI_DEFAULT_WORKSPACE=test-mcp
# POWERBI_DEFAULT_SEMANTIC_MODEL=hospital
