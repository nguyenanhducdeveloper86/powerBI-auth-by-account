# Optional override for the Microsoft Power BI Modeling MCP bridge.
# Defaults to the bundled native binary for the current OS when installed,
# otherwise falls back to npx.
# POWERBI_MODELING_MCP_COMMAND=npx
# POWERBI_MODELING_MCP_ARGS=-y @microsoft/powerbi-modeling-mcp@latest --start --authmode=interactive

# Claude/Desktop example after `npm install` in this repo:
# POWERBI_MODELING_MCP_COMMAND=/Users/ducna/powerBI-auth-by-account/node_modules/.bin/powerbi-modeling-mcp-darwin-arm64
# POWERBI_MODELING_MCP_ARGS=--start --authmode=interactive

# Windows example. Do not use npx on Windows for this command.
# POWERBI_MODELING_MCP_COMMAND=C:\Users\<you>\powerBI-auth-by-account\node_modules\@microsoft\powerbi-modeling-mcp-win32-x64\dist\powerbi-modeling-mcp.exe
# POWERBI_MODELING_MCP_ARGS=--start --authmode=interactive

# Optional CEO defaults. Known workspaces replace tenant-wide REST discovery
# because this repo intentionally does not use REST/device-code auth.
# POWERBI_KNOWN_WORKSPACES=test-mcp,finance,hospital
# POWERBI_DEFAULT_WORKSPACE=test-mcp
# POWERBI_DEFAULT_SEMANTIC_MODEL=hospital
